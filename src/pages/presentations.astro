---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Conferences and Seminars" sideBarActiveItemID="presentations">
  <div class="pb-12 mt-5">

    <h2 style="font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;color:#1C1917;letter-spacing:-0.01em;line-height:1.1;margin-bottom:8px;">Conferences &amp; Seminars</h2>
    <p style="font-family:'Lora',serif;font-size:14px;color:#6B6460;margin-bottom:48px;font-style:italic;">Presentations in conferences, seminars, and workshops</p>


    <!-- 2026 -->
    <div style="margin-bottom:40px;">
      <span class="section-label">2026</span>
      <div style="border-top:1px solid #E8E2D9;">

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Jornadas de Economía Laboral</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">14-19 Jun</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Málaga</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Society of Economics of the Household (SEHO)</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">3-4 Jun</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Pavia</span>
          </div>
        </div>


        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Meeting on Public Economics</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">21-22 May</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Valladolid</span>
          </div>
        </div>

      </div>
    </div>

    <!-- 2025 -->
    <div style="margin-bottom:40px;">
      <span class="section-label">2025</span>
      <div style="border-top:1px solid #E8E2D9;">

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">50th Simposio de la Asociación Española de Economía</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">17–19 Dec</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Barcelona</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Royal Economic Society 2025 Conference</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">30 Jun – 2 Jul</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Birmingham</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">International Association for Applied Econometrics (IAAE)</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">25–27 Jun</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Torino</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">European Society for Population Economics (ESPE)</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">12–14 Jun</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Naples Federico II</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Society of Economics of the Household (SEHO)</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">10–11 Jun</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Zaragoza</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Meeting on Public Economics</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">15–16 May</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Huelva</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">BSE PhD Jamboree 2025</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">8–9 May</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">Barcelona School of Economics</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Applied Lunch Seminar *</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">25 Mar</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">Autonomous University of Barcelona</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">*by invitation</span>

          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;text-wrap:pretty;">Gender Inequalities, Fertility, and the Future of Family Demography: Intersectionality in an Era of Family Complexity</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">19–21 Mar</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">Max Planck Institute for Demographic Research</span>
          </div>
        </div>

      </div>
    </div>

    <!-- 2024 -->
    <div>
      <span class="section-label">2024</span>
      <div style="border-top:1px solid #E8E2D9;">

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Virtual Workshop for Early Career Researchers on Family Research</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">28–29 Nov</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">Research Committee on Family Research, International Sociological Association</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">PAPERSS Seminar</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">12 Nov</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University Carlos III</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">UPF Student Seminar</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">10 Oct </span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Pompeu Fabra</span>
          </div>
        </div>

        <div class="entry-row-compact">
          <p style="font-family:'Lora',serif;font-size:15px;font-weight:500;color:#1C1917;line-height:1.45;margin-bottom:4px;">Jornadas de Economía Laboral</p>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">11-12 Jul</span>
            <span style="font-family:monospace;font-size:10px;color:#6B6460;letter-spacing:0.05em;">University of Barcelona</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</BaseLayout>
