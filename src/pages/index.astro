---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">

    <span class="section-label">About me</span>

    <p style="font-family:'Lora',serif;font-size:18px;line-height:1.85;color:#1C1917;max-width:620px;margin-bottom:22px;">
      Hi, I'm Natalia! I am a third-year PhD Student in Economics at <a href="https://www.ub.edu/web/ub/en/" target="_blank" style="color:#7D2035;text-decoration:none;border-bottom:1px solid rgba(125,32,53,0.38);">University of Barcelona</a> and at the <a href="https://ieb.ub.edu/" target="_blank" style="color:#7D2035;text-decoration:none;border-bottom:1px solid rgba(125,32,53,0.38);">Barcelona Institute of Economics</a> under the supervision of <a href="https://sites.google.com/site/anastasiaterskaya/" target="_blank" style="color:#7D2035;text-decoration:none;border-bottom:1px solid rgba(125,32,53,0.38);">Anastasia Terskaya</a> and <a href="http://www.saraayllon.eu/" target="_blank" style="color:#7D2035;text-decoration:none;border-bottom:1px solid rgba(125,32,53,0.38);">Sara Ayllón</a>.
    </p>

    <p style="font-family:'Lora',serif;font-size:18px;line-height:1.85;color:#1C1917;max-width:620px;margin-bottom:44px;">
      My research interests include <strong style="font-weight:600;">labour economics</strong>, <strong style="font-weight:600;">gender and family economics</strong>, and <strong style="font-weight:600;">policy evaluation</strong>.
    </p>

    <!-- Research tags -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:56px;">
      <span style="font-family:monospace;font-size:9px;letter-spacing:0.09em;color:#7D2035;text-transform:uppercase;border:1px solid rgba(125,32,53,0.32);padding:5px 13px;">Labour Economics</span>
      <span style="font-family:monospace;font-size:9px;letter-spacing:0.09em;color:#7D2035;text-transform:uppercase;border:1px solid rgba(125,32,53,0.32);padding:5px 13px;">Gender &amp; Family</span>
      <span style="font-family:monospace;font-size:9px;letter-spacing:0.09em;color:#7D2035;text-transform:uppercase;border:1px solid rgba(125,32,53,0.32);padding:5px 13px;">Policy Evaluation</span>
    </div>

    <!-- Affiliations -->
    <div style="border-top:1px solid #E8E2D9;padding-top:40px;">
      <span class="section-label">Affiliations</span>
      <div style="display:flex;gap:40px;flex-wrap:wrap;">
        <div>
          <p style="font-family:'Lora',serif;font-size:15px;color:#1C1917;font-weight:500;margin-bottom:3px;">University of Barcelona</p>
          <p style="font-family:'Lora',serif;font-size:13px;color:#6B6460;">Department of Economics</p>
        </div>
        <div>
          <p style="font-family:'Lora',serif;font-size:15px;color:#1C1917;font-weight:500;margin-bottom:3px;">Barcelona Institute of Economics</p>
          <p style="font-family:'Lora',serif;font-size:13px;color:#6B6460;">IEB</p>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
