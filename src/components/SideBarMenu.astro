---
const { sideBarActiveItemID } = Astro.props;
---

<nav class="grow shrink overflow-y-auto">
  <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;">
    <li style="border-bottom:1px solid #E5DED4;">
      <a id="home" href="/" style="display:block;padding:10px 0;font-family:'Lora',serif;font-size:14px;color:#3A3330;text-decoration:none;letter-spacing:0.02em;">Home</a>
    </li>
    <li style="border-bottom:1px solid #E5DED4;">
      <a id="research" href="/research" style="display:block;padding:10px 0;font-family:'Lora',serif;font-size:14px;color:#3A3330;text-decoration:none;letter-spacing:0.02em;">Research</a>
    </li>
    <li style="border-bottom:1px solid #E5DED4;">
      <a id="teaching" href="/teaching" style="display:block;padding:10px 0;font-family:'Lora',serif;font-size:14px;color:#3A3330;text-decoration:none;letter-spacing:0.02em;">Teaching</a>
    </li>
    <li style="border-bottom:1px solid #E5DED4;">
      <a id="presentations" href="/presentations" style="display:block;padding:10px 0;font-family:'Lora',serif;font-size:14px;color:#3A3330;text-decoration:none;letter-spacing:0.02em;">Conferences &amp; Seminars</a>
    </li>
    <li>
      <a id="cv" href="/CV_Natalia_Carralero.pdf" target="_blank" style="display:block;padding:10px 0;font-family:'Lora',serif;font-size:14px;color:#3A3330;text-decoration:none;letter-spacing:0.02em;">CV</a>
    </li>
  </ul>
</nav>

<script define:vars={{ sideBarActiveItemID }}>
  const el = document.getElementById(sideBarActiveItemID);
  if (el) {
    el.style.color = '#7D2035';
    el.style.fontWeight = '500';
  }
</script>
