---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-[#F0E0E0]"; // For primary color replace with `active` class
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li><a class="py-3 text-[#7D2035]" id="home" href="/">Home</a></li>
    <li>
        <a class="py-3 text-[#7D2035]" id="research" href="/research">Research</a>
    </li>
     <li>
        <a class="py-3 text-[#7D2035]" id="teaching" href="/teaching">Teaching</a>
    </li>   
    <li>
        <a class="py-3 text-[#7D2035]" id="presentations" href="/presentations">Conferences and seminars</a>
    </li>
    <!-- <li><a class="py-3 text-base" id="services" href="/teaching">Teaching</a></li> -->
    <li>
        <a
            class="py-3 text-[#7D2035]"
            id="cv"
            href="/CV_Natalia_Carralero.pdf"
            target="_blank">CV</a
        >
    </li>
</ul>

<script
    define:vars={{
        sideBarActiveItemID: sideBarActiveItemID,
        activeClass: activeClass,
    }}
>
    const activeItemElem = document.getElementById(sideBarActiveItemID);
    activeItemElem && activeItemElem.classList.add(activeClass);
</script>
