---
import SideBarFooter from "./SideBarFooter.astro";
import { Image } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
const { sideBarActiveItemID } = Astro.props;
---

<div class="drawer-side z-40">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside class="px-6 pt-8 h-auto min-h-full w-[19rem] text-base-content flex flex-col" style="background:#faf9f5;">

    <!-- Profile photo (small, circular) -->
    <div style="width:72px;height:72px;border-radius:50%;overflow:hidden;border:2px solid #DDD6CC;margin-bottom:24px;flex-shrink:0;">
      <a href="/">
        <Image
          format="webp"
          width={144}
          height={144}
          src="/profile.webp"
          alt="Profile image"
          style="width:100%;height:100%;object-fit:cover;display:block;"
        />
      </a>
    </div>

    <!-- Name -->
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:#1C1917;line-height:1.1;letter-spacing:-0.01em;margin-bottom:12px;">
      Natalia<br>Carralero
    </h1>

    <!-- Accent line -->
    <div style="width:28px;height:1.5px;background:#7D2035;margin-bottom:10px;flex-shrink:0;"></div>

    <!-- Title -->
    <p style="font-family:monospace;font-size:10px;color:#7D2035;letter-spacing:0.09em;text-transform:uppercase;line-height:1.6;margin-bottom:32px;">
      PhD Candidate<br>in Economics
    </p>

    <!-- Separator -->
    <div style="height:1px;background:#E5DED4;margin-bottom:8px;"></div>

    <SideBarMenu sideBarActiveItemID={sideBarActiveItemID} />
    <SideBarFooter />
  </aside>
</div>
